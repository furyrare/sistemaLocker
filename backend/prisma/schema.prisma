generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Compartimento {
  id               String         @id
  armarioId        String
  numero           Int
  tamanho          String         @default("UNICO") @db.NVarChar(16)
  status           String         @default("DISPONIVEL") @db.NVarChar(24)
  dataCriacao      DateTime       @default(now())
  dataAtualizacao  DateTime
  Armario          Armario        @relation(fields: [armarioId], references: [id])
  Entrega          Entrega[]
  ControlePorta    ControlePorta?

  @@unique([armarioId, numero])
  @@index([armarioId, status])
  @@map("Compartimentos")
}

model Entrega {
  id                String      @id
  armarioId         String
  compartimentoId   String
  emailDestinatario String
  nomeDestinatario  String
  telefoneDestinatario String   @db.VarChar(20)
  codigoRetirada    String
  descricao         String
  numeroPedido      String      @db.VarChar(50)
  status            String      @default("PENDENTE_DEPOSITO") @db.NVarChar(32)
  dataCriacao       DateTime    @default(now())
  dataDeposito      DateTime?
  dataNotificacao   DateTime?
  dataRetirada      DateTime?
  codigoDeposito    String?
  emailRemetente    String?     @db.VarChar(255)
  Compartimento     Compartimento @relation(fields: [compartimentoId], references: [id], onUpdate: NoAction)
  Armario           Armario      @relation(fields: [armarioId], references: [id], onUpdate: NoAction)
  RetiradaLog       RetiradaLog[]

  @@index([codigoDeposito])
  @@index([codigoRetirada])
  @@index([status])
  @@map("Entregas")
}

model ControlePorta {
  id               String       @id
  compartimentoId  String       @unique
  status           String       @default("FECHADA") @db.NVarChar(16)
  ultimoComando    String?      @db.NVarChar(32)
  ultimaResposta   String?      @db.VarChar(255)
  dataCriacao      DateTime     @default(now())
  dataAtualizacao  DateTime
  esp32DeviceId    String?
  Compartimento    Compartimento @relation(fields: [compartimentoId], references: [id], onUpdate: NoAction)
  ESP32Device      ESP32Device? @relation(fields: [esp32DeviceId], references: [id], onUpdate: NoAction)

  @@index([status])
  @@map("ControlePortas")
}

model ESP32Device {
  id               String        @id
  deviceId         String        @unique @db.VarChar(32)
  armarioId        String
  enderecoIP       String        @db.VarChar(15)
  status           String        @default("ONLINE") @db.NVarChar(16)
  ultimoAcesso     DateTime      @default(now())
  dataCriacao      DateTime      @default(now())
  dataAtualizacao  DateTime
  ControlePorta    ControlePorta[]
  Armario          Armario        @relation(fields: [armarioId], references: [id])

  @@index([deviceId])
  @@index([status])
  @@map("ESP32Devices")
}

model Armario {
  id               String        @id
  nome             String
  localizacao      String
  endereco         String?       @db.NVarChar(255)
  dataCriacao      DateTime      @default(now())
  dataAtualizacao  DateTime
  Compartimento    Compartimento[]
  Entrega          Entrega[]
  ESP32Device      ESP32Device[]

  @@map("Armarios")
}

model RetiradaLog {
  id         String   @id
  entregaId  String
  enderecoIP String?
  dataCriacao DateTime @default(now())
  Entrega    Entrega  @relation(fields: [entregaId], references: [id])

  @@index([entregaId])
  @@map("RetiradaLogs")
}

model Usuario {
  id               String   @id
  nome             String
  email            String   @unique
  senha            String
  dataCriacao      DateTime @default(now())
  dataAtualizacao  DateTime

  @@map("Usuarios")
}
